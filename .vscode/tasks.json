{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "fontVersion",
            "type": "promptString",
            "description": "请输入字体版本号",
            "default": "1.0.0",
        },
        {
            "id": "seeyngpingWeight",
            "type": "pickString",
            "description": "选择 SeeYngping 字重",
            "options": [
                "Regular",
                "Bold"
            ],
            "default": "Regular"
        }
    ],
    "tasks": [
        // 1.1 SeeYngping 基础流程
        {
            "label": "SeeYngping: collect yngping",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/collect_charset.py",
                "${workspaceFolder}/data/yngping.txt",
                "${workspaceFolder}/data/charset-yngping.txt",
            ],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "panel": "shared"
            },
        },
        {
            "label": "SeeYngping: subset andika",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/subset_font.py",
                "${workspaceFolder}/fonts/Andika-${input:seeyngpingWeight}.ttf",
                "${workspaceFolder}/data/charset-ipatone.txt",
                "${workspaceFolder}/output/Andika-ipatone-${input:seeyngpingWeight}.ttf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeYngping: subset notosans",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/subset_font.py",
                "${workspaceFolder}/fonts/NotoSans-${input:seeyngpingWeight}.ttf",
                "${workspaceFolder}/data/charset-yngping.txt",
                "${workspaceFolder}/output/NotoSans-yngping-${input:seeyngpingWeight}.ttf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeYngping: scale notosans upem",
            "type": "shell",
            "dependsOn": [
                "SeeYngping: subset notosans"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\fonttools.exe",
            "args": [
                "ttLib.scaleUpem",
                "${workspaceFolder}/output/NotoSans-yngping-${input:seeyngpingWeight}.ttf",
                "2048",
                "--output-file",
                "${workspaceFolder}/output/NotoSans-yngping-${input:seeyngpingWeight}-scaled.ttf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeYngping: merge",
            "type": "shell",
            "dependsOn": [
                "SeeYngping: subset andika",
                "SeeYngping: scale notosans upem"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/merge_fonts.py",
                "${workspaceFolder}/output/NotoSans-yngping-${input:seeyngpingWeight}-scaled.ttf",
                "${workspaceFolder}/output/Andika-ipatone-${input:seeyngpingWeight}.ttf",
                "${workspaceFolder}/output/SeeYngping-${input:seeyngpingWeight}.ttf",
                "--family",
                "SeeYngping",
                "--style",
                "${input:seeyngpingWeight}",
                "--full-name",
                "SeeYngping ${input:seeyngpingWeight}",
                "--version",
                "${input:fontVersion}",
                "--copyright",
                "© 2025 SeeDict"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeYngping: build",
            "type": "shell",
            "dependsOn": [
                "SeeYngping: merge"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/charset_pdf.py",
                "${workspaceFolder}/output/SeeYngping-${input:seeyngpingWeight}.ttf",
                "${workspaceFolder}/output/SeeYngping-${input:seeyngpingWeight}-charset.pdf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        // 1.2 SeeYngping 单字重发布
        {
            "label": "SeeYngping: dist regular",
            "type": "shell",
            "dependsOn": [
                {
                    "task": "SeeYngping: build",
                    "inputs": [
                        {
                            "id": "seeyngpingWeight",
                            "value": "Regular"
                        }
                    ]
                }
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/dist_webfont.py",
                "${workspaceFolder}/output/SeeYngping-Regular.ttf",
                "${workspaceFolder}/dist/SeeYngping",
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeYngping: dist bold",
            "type": "shell",
            "dependsOn": [
                {
                    "task": "SeeYngping: build",
                    "inputs": [
                        {
                            "id": "seeyngpingWeight",
                            "value": "Bold"
                        }
                    ]
                },
                "SeeYngping: dist regular"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/dist_webfont.py",
                "${workspaceFolder}/output/SeeYngping-Bold.ttf",
                "${workspaceFolder}/dist/SeeYngping",
                "--append"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        // 1.3 SeeYngping 总发布
        {
            "label": "SeeYngping: dist all",
            "type": "shell",
            "dependsOn": [
                "SeeYngping: dist regular",
                "SeeYngping: dist bold"
            ],
            "command": "echo",
            "args": [
                "成功发布 SeeYngping 所有字重，目录：${workspaceFolder}/dist/SeeYngping"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "focus": false
            }
        },
        // 2. SeeFont 字体
        {
            "label": "SeeFont: collect han",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/collect_charset.py",
                "${workspaceFolder}/data/han.txt",
                "${workspaceFolder}/data/charset-han.txt",
            ],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "panel": "shared"
            },
        },
        {
            "label": "SeeFont: subset",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/subset_font.py",
                "${workspaceFolder}/fonts/PlangothicP1-Regular.ttf",
                "${workspaceFolder}/fonts/PlangothicP2-Regular.ttf",
                "${workspaceFolder}/data/charset-han.txt",
                "${workspaceFolder}/output/SeeFont-Regular.ttf",
                "--family",
                "SeeFont",
                "--style",
                "Regular",
                "--full-name",
                "SeeFont Regular",
                "--version",
                "${input:fontVersion}",
                "--copyright",
                "© 2025 SeeDict"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeFont: build",
            "type": "shell",
            "dependsOn": [
                "SeeFont: subset"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/charset_pdf.py",
                "${workspaceFolder}/output/SeeFont-Regular.ttf",
                "${workspaceFolder}/output/SeeFont-Regular-charset.pdf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeFont: dist",
            "type": "shell",
            "dependsOn": [
                "SeeFont: build"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/dist_webfont.py",
                "${workspaceFolder}/output/SeeFont-Regular.ttf",
                "${workspaceFolder}/dist/SeeFont"
            ],
            "group": "build",
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeFontEx: collect han-ex",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/collect_charset.py",
                "${workspaceFolder}/data/han-ex.txt",
                "${workspaceFolder}/data/charset-han-ex.txt",
            ],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "panel": "shared"
            },
        },
        {
            "label": "SeeFontEx: subset",
            "type": "shell",
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/subset_font.py",
                "${workspaceFolder}/fonts/PlangothicP1-Regular.ttf",
                "${workspaceFolder}/fonts/PlangothicP2-Regular.ttf",
                "${workspaceFolder}/data/charset-han-ex.txt",
                "${workspaceFolder}/output/SeeFontEx-Regular.ttf",
                "--family",
                "SeeFontEx",
                "--style",
                "Regular",
                "--full-name",
                "SeeFontEx Regular",
                "--version",
                "${input:fontVersion}",
                "--copyright",
                "© 2025 SeeDict"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeFontEx: build",
            "type": "shell",
            "dependsOn": [
                "SeeFontEx: subset"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/charset_pdf.py",
                "${workspaceFolder}/output/SeeFontEx-Regular.ttf",
                "${workspaceFolder}/output/SeeFontEx-Regular-charset.pdf"
            ],
            "presentation": {
                "panel": "shared"
            }
        },
        {
            "label": "SeeFontEx: dist",
            "type": "shell",
            "dependsOn": [
                "SeeFontEx: build"
            ],
            "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
            "args": [
                "${workspaceFolder}/src/dist_webfont.py",
                "${workspaceFolder}/output/SeeFontEx-Regular.ttf",
                "${workspaceFolder}/dist/SeeFontEx"
            ],
            "group": "build",
            "presentation": {
                "panel": "shared"
            }
        },
        // 3. 总任务（所有字体 + 所有字重）
        {
            "label": "All: dist all fonts",
            "type": "shell",
            "dependsOn": [
                "SeeYngping: dist all",
                "SeeFont: dist",
                "SeeFontEx: dist"
            ],
            "command": "echo",
            "args": [
                "成功发布字体 SeeYngping 与 SeeFont ，目录：${workspaceFolder}/dist"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        }
    ]
}